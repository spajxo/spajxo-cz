<section class="space-y-8">
    <div class="space-y-2">
        <p class="font-mono text-sm text-primary tracking-wider uppercase">Co dělám</p>
        <h2 class="text-3xl font-bold tracking-tight font-mono">Technologie & Skills</h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
        <twig:Card>
            <twig:Card:Header>
                <twig:Card:Title>Backend & API</twig:Card:Title>
                <twig:Card:Description>Serverová strana, messaging a API design</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="flex flex-wrap gap-2">
                    {% for skill in ['PHP', 'Symfony', 'Doctrine ORM', 'OpenAPI', 'PostgreSQL', 'Redis', 'RabbitMQ', 'Symfony Messenger', 'CloudEvents'] %}
                        <span class="rounded-md bg-secondary px-2.5 py-1 text-sm text-secondary-foreground">{{ skill }}</span>
                    {% endfor %}
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card>
            <twig:Card:Header>
                <twig:Card:Title>Architektura & Platformy</twig:Card:Title>
                <twig:Card:Description>Enterprise systémy, EDA a modernizace</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="flex flex-wrap gap-2">
                    {% for skill in ['Event-Driven Architecture', 'C4 Model', 'API-first Design', 'OIDC / ZITADEL', 'ADR', 'Microservices'] %}
                        <span class="rounded-md bg-secondary px-2.5 py-1 text-sm text-secondary-foreground">{{ skill }}</span>
                    {% endfor %}
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card>
            <twig:Card:Header>
                <twig:Card:Title>Infrastruktura & DevOps</twig:Card:Title>
                <twig:Card:Description>Nasazení, IaC a observability</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="flex flex-wrap gap-2">
                    {% for skill in ['Docker', 'Terraform', 'GitLab CI', 'GitHub Actions', 'Traefik', 'ELK Stack', 'GitOps', 'Linux'] %}
                        <span class="rounded-md bg-secondary px-2.5 py-1 text-sm text-secondary-foreground">{{ skill }}</span>
                    {% endfor %}
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card>
            <twig:Card:Header>
                <twig:Card:Title>Developer Experience & AI</twig:Card:Title>
                <twig:Card:Description>AI-assisted vývoj a interní tooling</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="flex flex-wrap gap-2">
                    {% for skill in ['Claude Code', 'MCP Integrations', 'Claude API', 'CLAUDE.md', 'glab CLI', 'Agentic Workflows'] %}
                        <span class="rounded-md bg-secondary px-2.5 py-1 text-sm text-secondary-foreground">{{ skill }}</span>
                    {% endfor %}
                </div>
            </twig:Card:Content>
        </twig:Card>
    </div>
</section>
