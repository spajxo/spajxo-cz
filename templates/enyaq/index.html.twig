{% extends 'base.html.twig' %}

{% block title %}Enyaq | spajxo.cz{% endblock %}

{% block body %}
    <main class="flex min-h-[80vh] items-center justify-center px-6">
        <div class="text-center space-y-3">
            <p class="text-6xl sm:text-8xl font-bold font-mono tracking-tight" id="expected-km">&ndash;</p>
            <p class="text-muted-foreground text-xl">km</p>
        </div>
    </main>

    <script>
        (function () {
            const START = new Date(2026, 0, 22);
            const YEARLY_KM = 15000;

            const now = new Date();
            const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

            const msPerDay = 86400000;
            const daysElapsed = Math.max(0, Math.floor((today - START) / msPerDay));
            const yearsElapsed = daysElapsed / 365.25;
            const expectedKm = Math.round(yearsElapsed * YEARLY_KM);

            document.getElementById('expected-km').textContent =
                new Intl.NumberFormat('cs-CZ').format(expectedKm);
        })();
    </script>
{% endblock %}
